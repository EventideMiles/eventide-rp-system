          </span>
          <span class="erps-toggles__track">
            <span class="erps-toggles__thumb"></span>
          </span>
        </div>
      </label>
      <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SelfTarget.hint"}}</p>
    </div>

    {{!-- Scale Self-Effects Per Target Toggle --}}
    <div class="eventide-sheet__toggle-group">
      <label class="erps-toggles erps-toggles--label-left">
        <input
          type="checkbox"
          class="erps-toggles__input"
          name="system.selfEffectsScalePerTarget"
          id="system.selfEffectsScalePerTarget"
          {{checked system.selfEffectsScalePerTarget}}
        />
        <div class="erps-toggles__container">
          <span class="erps-toggles__label" title='{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SelfEffectsScalePerTarget.hint"}}'>
            {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SelfEffectsScalePerTarget.label"}}
          </span>
          <span class="erps-toggles__track">
