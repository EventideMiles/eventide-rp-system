<section class="tab action-card-config {{tab.cssClass}}" 
         data-group="primary" data-tab="config">
  <div class="eventide-sheet__scrollable-container">
    
    {{!-- Repetitions Section --}}
  <div class="erps-form__section">
    <h3 class="erps-form__header">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Config.RepetitionsHeader"}}</h3>
    <div class="grid grid-4col">
      <div class="erps-form__group">
        <label class="erps-input-label" for="{{item.id}}-repetitions">
          {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Repetitions.label"}}
        </label>
        <input type="text"
               id="{{item.id}}-repetitions"
               name="system.repetitions"
               value="{{item.system.repetitions}}"
               placeholder="1"
               class="erps-input"
               data-dtype="String" />
        <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Repetitions.hint"}}</p>
      </div>

      <div class="erps-form__group">
        <label class="erps-input-label" for="{{item.id}}-timing-override">
          {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.TimingOverride.label"}}
        </label>
        <input type="number"
               id="{{item.id}}-timing-override"
               name="system.timingOverride"
               value="{{item.system.timingOverride}}"
               min="0"
               step="0.1"
               class="erps-input"
               data-dtype="Number" />
        <p class="erps-form__hint">{{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.TimingOverride.hint"}}}</p>
      </div>

      <div class="erps-form__group">
        <label class="erps-input-label" for="{{item.id}}-status-application-limit">
          {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.StatusApplicationLimit.label"}}
        </label>
        <input type="number"
               id="{{item.id}}-status-application-limit"
               name="system.statusApplicationLimit"
               value="{{item.system.statusApplicationLimit}}"
               min="0"
               step="1"
               class="erps-input"
               data-dtype="Number" />
        <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.StatusApplicationLimit.hint"}}</p>
      </div>

      <div class="erps-form__group">
        <label class="erps-input-label" for="{{item.id}}-self-effects-application-limit">
          {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SelfEffectsApplicationLimit"}}
        </label>
        <input type="number"
               id="{{item.id}}-self-effects-application-limit"
               name="system.selfEffectsApplicationLimit"
               value="{{item.system.selfEffectsApplicationLimit}}"
               min="0"
               step="1"
               class="erps-input"
               data-dtype="Number" />
        <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SelfEffectsApplicationLimitHint"}}</p>
      </div>
    </div>
  </div>

  {{!-- Boolean Configuration Section --}}
  <div class="erps-form__section">
    <h3 class="erps-form__header">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Config.BehaviorHeader"}}</h3>
    
    {{!-- Repeat to Hit Toggle --}}
    <div class="eventide-sheet__toggle-group">
      <label class="erps-toggles erps-toggles--label-left">
        <input
          type="checkbox"
          class="erps-toggles__input"
          name="system.repeatToHit"
          id="system.repeatToHit"
          {{checked system.repeatToHit}}
        />
        <div class="erps-toggles__container">
          <span class="erps-toggles__label" title='{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RepeatToHit.hint"}}'>
            {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RepeatToHit.label"}}
          </span>
          <span class="erps-toggles__track">
            <span class="erps-toggles__thumb"></span>
          </span>
        </div>
      </label>
      <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RepeatToHit.hint"}}</p>
    </div>

    {{!-- Damage Application Toggle --}}
    <div class="eventide-sheet__toggle-group">
      <label class="erps-toggles erps-toggles--label-left">
        <input
          type="checkbox"
          class="erps-toggles__input"
          name="system.damageApplication"
          id="system.damageApplication"
          {{checked system.damageApplication}}
        />
