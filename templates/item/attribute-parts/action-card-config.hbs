            {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.FailOnFirstMiss.label"}}
          </span>
          <span class="erps-toggles__track">
            <span class="erps-toggles__thumb"></span>
          </span>
        </div>
      </label>
      <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.FailOnFirstMiss.hint"}}</p>
    </div>

    {{!-- Enforce Status Choice Toggle --}}
    <div class="eventide-sheet__toggle-group">
      <label class="erps-toggles erps-toggles--label-left">
        <input
          type="checkbox"
          class="erps-toggles__input"
          name="system.enforceStatusChoice"
          id="system.enforceStatusChoice"
          {{checked system.enforceStatusChoice}}
        />
        <div class="erps-toggles__container">
          <span class="erps-toggles__label" title='{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.EnforceStatusChoice.hint"}}'>
            {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.EnforceStatusChoice.label"}}
          </span>
          <span class="erps-toggles__track">
            <span class="erps-toggles__thumb"></span>
          </span>
        </div>
      </label>
      <p class="erps-form__hint">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.EnforceStatusChoice.hint"}}</p>
    </div>

    {{!-- Self-Target Toggle --}}
