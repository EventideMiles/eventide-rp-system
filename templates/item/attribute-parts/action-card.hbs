                {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.StatusCondition"}}
              </label>
              <select class="erps-select" name="system.attackChain.statusCondition">
                <option value="never" {{#if (eq system.attackChain.statusCondition "never")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.Never'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Never"}}
                </option>
                <option value="oneSuccess" {{#if (eq system.attackChain.statusCondition "oneSuccess")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.OneSuccess'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.OneSuccess"}}
                </option>
                <option value="twoSuccesses" {{#if (eq system.attackChain.statusCondition "twoSuccesses")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.TwoSuccesses'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.TwoSuccesses"}}
                </option>
                <option value="rollValue" {{#if (eq system.attackChain.statusCondition "rollValue")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollValueHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollValue"}}
                </option>
                <option value="rollUnderValue" {{#if (eq system.attackChain.statusCondition "rollUnderValue")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollUnderValueHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollUnderValue"}}
                </option>
                <option value="rollEven" {{#if (eq system.attackChain.statusCondition "rollEven")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollEvenHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollEven"}}
                </option>
                <option value="rollOdd" {{#if (eq system.attackChain.statusCondition "rollOdd")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOddHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOdd"}}
                </option>
                <option value="rollOnValue" {{#if (eq system.attackChain.statusCondition "rollOnValue")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOnValueHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOnValue"}}
                </option>
                <option value="zeroSuccesses" {{#if (eq system.attackChain.statusCondition "zeroSuccesses")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.ZeroSuccessesHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.ZeroSuccesses"}}
                </option>
                <option value="always" {{#if (eq system.attackChain.statusCondition "always")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.AlwaysHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Always"}}
                </option>
                <option value="criticalSuccess" {{#if (eq system.attackChain.statusCondition "criticalSuccess")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalSuccessHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalSuccess"}}
                </option>
                <option value="criticalFailure" {{#if (eq system.attackChain.statusCondition "criticalFailure")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalFailureHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalFailure"}}
                </option>
              </select>
            </div>
            {{#if (or (eq system.attackChain.statusCondition "rollValue") (eq system.attackChain.statusCondition "rollUnderValue") (eq system.attackChain.statusCondition "rollOnValue"))}}
            <div>
              <label class="erps-input-label">
                {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.StatusThreshold"}}
              </label>
              <input
                type="number"
                class="erps-input"
                name="system.attackChain.statusThreshold"
                value="{{system.attackChain.statusThreshold}}"
                min="1"
                placeholder="15"
              />
            </div>
            {{/if}}
          </div>
        </div>


            {{!-- Self-Effects Configuration --}}
