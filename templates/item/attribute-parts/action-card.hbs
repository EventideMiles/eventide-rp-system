            </option>
            <option value="criticalFailure" {{#if (eq system.selfEffectsConfig.condition "criticalFailure")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.Conditions.CriticalFailureHint'}}">
              {{localize "EVENTIDE_RP_SYSTEM.Item.Conditions.CriticalFailure"}}
            </option>
          </select>
        </div>
        {{#if (or (eq system.selfEffectsConfig.condition "rollValue") (eq system.selfEffectsConfig.condition "rollUnderValue") (eq system.selfEffectsConfig.condition "rollOnValue"))}}
