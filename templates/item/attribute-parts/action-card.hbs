{{!-- Action Card Attributes Tab --}}
<section class="tab action-card-attributes {{tab.cssClass}}" data-group="primary" data-tab="attributes">
  <div class="eventide-sheet__scrollable-container">

    {{!-- Mode Selection --}}
    <div class="erps-form__section">
      <div class="erps-form__header">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Mode"}}</div>

      <div>
        <label class="erps-input-label">
          {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SelectMode"}}
        </label>
        <select class="erps-select" name="system.mode">
          <option value="attackChain" {{#if (eq system.mode "attackChain")}}selected{{/if}}>
            {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.AttackChainMode"}}
          </option>
          <option value="savedDamage" {{#if (eq system.mode "savedDamage")}}selected{{/if}}>
            {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SavedDamageMode"}}
          </option>
        </select>
      </div>

      {{!-- Advance Initiative Toggle --}}
      <div class="eventide-sheet__toggle-group">
        <label class="erps-toggles erps-toggles--label-left">
          <input
            type="checkbox"
            class="erps-toggles__input"
            name="system.advanceInitiative"
            id="system.advanceInitiative"
            {{checked system.advanceInitiative}}
          />
          <div class="erps-toggles__container">
            <span class="erps-toggles__label" title='{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.AdvanceInitiative.label"}}'>
              {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.AdvanceInitiative.label"}}
            </span>
            <span class="erps-toggles__track">
              <span class="erps-toggles__thumb"></span>
            </span>
          </div>
        </label>
      </div>

      {{!-- Attempt Inventory Reduction Toggle --}}
      <div class="eventide-sheet__toggle-group">
        <label class="erps-toggles erps-toggles--label-left">
          <input
            type="checkbox"
            class="erps-toggles__input"
            name="system.attemptInventoryReduction"
            id="system.attemptInventoryReduction"
            {{checked system.attemptInventoryReduction}}
          />
          <div class="erps-toggles__container">
            <span class="erps-toggles__label" title='{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.AttemptInventoryReduction.label"}}'>
              {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.AttemptInventoryReduction.label"}}
            </span>
            <span class="erps-toggles__track">
              <span class="erps-toggles__thumb"></span>
            </span>
          </div>
        </label>
      </div>

      {{!-- GM Only Toggle --}}
      <div class="eventide-sheet__toggle-group">
        <label class="erps-toggles erps-toggles--label-left">
          <input
            type="checkbox"
            class="erps-toggles__input"
            name="system.gmOnly"
            id="system.gmOnly"
            {{checked system.gmOnly}}
          />
          <div class="erps-toggles__container">
            <span class="erps-toggles__label" title='{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.GmOnly.hint"}}'>
              {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.GmOnly.label"}}
            </span>
            <span class="erps-toggles__track">
              <span class="erps-toggles__thumb"></span>
            </span>
          </div>
        </label>
      </div>
    </div>

    {{!-- Attack Chain Configuration --}}
    {{#if (eq system.mode "attackChain")}}
    <div class="erps-form__section">
      <div class="erps-form__header">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.AttackChain"}}</div>
        <div class="grid grid-2col">
          <div>
            <label class="erps-input-label">
              {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.FirstStat"}}
            </label>
            <select class="erps-select" name="system.attackChain.firstStat">
              {{#each abilities as |name key|}}
                {{#unless (eq key "unaugmented")}}
                  <option value="{{key}}" {{#if (eq ../system.attackChain.firstStat key)}}selected{{/if}}>
                    {{localize (lookup @root.config.abilities key)}}
                  </option>
                {{/unless}}
              {{/each}}
            </select>
          </div>
          <div>
            <label class="erps-input-label">
              {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.SecondStat"}}
            </label>
            <select class="erps-select" name="system.attackChain.secondStat">
              {{#each abilities as |name key|}}
                {{#unless (eq key "unaugmented")}}
                  <option value="{{key}}" {{#if (eq ../system.attackChain.secondStat key)}}selected{{/if}}>
                    {{localize (lookup @root.config.abilities key)}}
                  </option>
                {{/unless}}
              {{/each}}
            </select>
          </div>
        </div>

        {{!-- Damage Configuration --}}
        <div class="erps-form__subsection">
          <div class="erps-form__header erps-form__header--small">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.DamageConfig"}}</div>

          <div class="grid grid-3col">
            <div>
              <label class="erps-input-label">
                {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.DamageCondition"}}
              </label>
              <select class="erps-select" name="system.attackChain.damageCondition">
                <option value="never" {{#if (eq system.attackChain.damageCondition "never")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.Never'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Never"}}
                </option>
                <option value="oneSuccess" {{#if (eq system.attackChain.damageCondition "oneSuccess")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.OneSuccess'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.OneSuccess"}}
                </option>
                <option value="twoSuccesses" {{#if (eq system.attackChain.damageCondition "twoSuccesses")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.TwoSuccesses'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.TwoSuccesses"}}
                </option>
                <option value="rollValue" {{#if (eq system.attackChain.damageCondition "rollValue")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollValueHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollValue"}}
                </option>
                <option value="rollUnderValue" {{#if (eq system.attackChain.damageCondition "rollUnderValue")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollUnderValueHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollUnderValue"}}
                </option>
                <option value="rollEven" {{#if (eq system.attackChain.damageCondition "rollEven")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollEvenHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollEven"}}
                </option>
                <option value="rollOdd" {{#if (eq system.attackChain.damageCondition "rollOdd")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOddHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOdd"}}
                </option>
                <option value="rollOnValue" {{#if (eq system.attackChain.damageCondition "rollOnValue")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOnValueHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.RollOnValue"}}
                </option>
                <option value="zeroSuccesses" {{#if (eq system.attackChain.damageCondition "zeroSuccesses")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.ZeroSuccessesHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.ZeroSuccesses"}}
                </option>
                <option value="always" {{#if (eq system.attackChain.damageCondition "always")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.AlwaysHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Always"}}
                </option>
                <option value="criticalSuccess" {{#if (eq system.attackChain.damageCondition "criticalSuccess")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalSuccessHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalSuccess"}}
                </option>
                <option value="criticalFailure" {{#if (eq system.attackChain.damageCondition "criticalFailure")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalFailureHint'}}">
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.CriticalFailure"}}
                </option>
              </select>
            </div>
            <div>
              <label class="erps-input-label">
                {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.DamageFormula"}}
              </label>
              <input
                type="text"
                class="erps-input"
                name="system.attackChain.damageFormula"
                value="{{system.attackChain.damageFormula}}"
                placeholder="1d6"
              />
            </div>
            <div>
              <label class="erps-input-label">
                {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.DamageType"}}
              </label>
              <select class="erps-select" name="system.attackChain.damageType">
                <option value="damage" {{#if (eq system.attackChain.damageType "damage")}}selected{{/if}}>
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Damage"}}
                </option>
                <option value="heal" {{#if (eq system.attackChain.damageType "heal")}}selected{{/if}}>
                  {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.Heal"}}
                </option>
              </select>
            </div>
            {{#if (or (eq system.attackChain.damageCondition "rollValue") (eq system.attackChain.damageCondition "rollUnderValue") (eq system.attackChain.damageCondition "rollOnValue"))}}
            <div>
              <label class="erps-input-label">
                {{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.DamageThreshold"}}
              </label>
              <input
                type="number"
                class="erps-input"
                name="system.attackChain.damageThreshold"
                value="{{system.attackChain.damageThreshold}}"
                min="1"
                placeholder="15"
              />
            </div>
            {{/if}}
          </div>
        </div>

        {{!-- Status Configuration --}}
        <div class="erps-form__subsection">
          <div class="erps-form__header erps-form__header--small">{{localize "EVENTIDE_RP_SYSTEM.Item.ActionCard.StatusConfig"}}</div>

          <div class="grid grid-2col">
            <div>
