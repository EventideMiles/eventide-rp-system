            </option>
            <option value="criticalSuccess" {{#if (eq system.selfEffectsConfig.condition "criticalSuccess")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.Conditions.CriticalSuccessHint'}}">
