            </option>
            <option value="zeroSuccesses" {{#if (eq system.selfEffectsConfig.condition "zeroSuccesses")}}selected{{/if}} title="{{localize 'EVENTIDE_RP_SYSTEM.Item.Conditions.ZeroSuccessesHint'}}">
