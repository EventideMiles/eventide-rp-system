<div class="chat-card">
  <div class="chat-card__header chat-card__header--equip chat-card__header--image">
    <div>
      {{#if (eq action "equipped")}}
        {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Equipped"}} {{count}}
      {{else}}
        {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Unequipped"}} {{count}}
      {{/if}}
    </div>
  </div>
  <div class="chat-card__description">
    <div class="chat-card__description--header">{{actor.name}}</div>
    <ul>
      {{#each items}}
        <li>{{this.name}}</li>
      {{/each}}
    </ul>
  </div>
</div>
