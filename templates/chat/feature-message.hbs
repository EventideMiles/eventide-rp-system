<div class="chat-card">
<div class="chat-card__header chat-card__header--status chat-card__header--image" style="{{style}}">
  <img src="{{item.img}}" class="chat-card__image--primary" alt="{{item.name}}" title="Click to enlarge" />
  <div>{{item.name}}</div>
</div>

{{#unless isActive}}
  <div class="chat-card__status-badge chat-card__status-badge--inactive">
    <i class="fas fa-power-off"></i>
    {{localize "EVENTIDE_RP_SYSTEM.UI.Inactive"}}
  </div>
{{/unless}}

{{!-- Roll information section --}}
{{#if hasRoll}}
  {{> roll-info cardClass="combat-roll" cardType="feature"}}
  {{> card-ac-check}}
{{/if}}

{{#if item.system.description}}
  <div class="chat-card__description">
    {{#if item.system.rollActorName}}
      <div class="chat-card__description--header">{{item.actor.name}}. . . </div>
    {{/if}}
    {{{enrichedDescription}}}
  </div>
{{/if}}
  {{> card-effects}}
</div>
