{{!-- Popup Effects --}}
{{#if mainEffect.system.changes.length}}
  <div class="erps-form__section erps-form__section--compact">
    <div class="erps-form__header erps-form__header--small erps-form__header--no-margin">{{localize "EVENTIDE_RP_SYSTEM.Forms.Sections.Effects"}}</div>
    <div class="erps-form__description erps-form__description--compact erps-form__description--no-margin">
      <img src="{{mainEffect.img}}" class="erps-form__image erps-form__image--small" /> {{mainEffect.name}}
    </div>
    
    <div class="erps-form__effects-list">
      {{#each mainEffect.system.changes}}
        <div class="erps-form__effects-row">
          <span class="erps-form__effects-ability">{{keySplit this.key 2}}</span>
          <span class="erps-form__effects-mode">
            {{#if (eq this.type "override")}}
              {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.SetTo"}}
            {{else if (eq this.type "multiply")}}
              {{!-- Multiply modes are at index 3 (direct children of ability) --}}
              {{#if (eq (keySplit this.key 3) "multiplyNeutral")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Mlt"}}
              {{else if (eq (keySplit this.key 3) "divideNeutral")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Dvd"}}
              {{else if (eq (keySplit this.key 3) "multiplyBuff")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.MltB"}}
              {{else if (eq (keySplit this.key 3) "multiplyDebuff")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.MltD"}}
              {{else}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Mlt"}}
              {{/if}}
            {{else}}
              {{#if (eq (keySplit this.key 4) "advantage")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Adv"}}
              {{/if}}
              {{#if (eq (keySplit this.key 4) "disadvantage")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Dis"}}
              {{/if}}
              {{#if (and (eq (keySplit this.key 3) "ac") (eq (keySplit this.key 4) "change"))}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.AC"}}
              {{/if}}
              {{#if (eq (keySplit this.key 3) "change")}}
                {{localize "EVENTIDE_RP_SYSTEM.Messages.Sections.Add"}}
              {{/if}}
            {{/if}}
          </span>
          <span class="erps-form__effects-value">{{this.value}}</span>
        </div>
      {{/each}}
    </div>
  </div>
{{/if}}